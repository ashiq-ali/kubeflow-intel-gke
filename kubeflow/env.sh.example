#!/usr/bin/env bash
# Kubeflow cluster configuration
# Copy to env.sh and fill in your values — env.sh is gitignored

export KF_PROJECT=my-gcp-project
export KF_NAME=kubeflow
export ZONE=us-central1-a
export REGION=us-central1

# OAuth credentials (from GCP Console → APIs & Services → Credentials)
export CLIENT_ID=<your-oauth-client-id>
export CLIENT_SECRET=<your-oauth-client-secret>

# Intel Xeon C3 instance type for ML workloads
# c3-standard-8  →  8 vCPU  / 32GB  (good starting point)
# c3-standard-22 → 22 vCPU  / 88GB  (mid-range training)
# c3-standard-44 → 44 vCPU  / 176GB (large model training)
export KF_INSTANCE_TYPE=c3-standard-8
export KF_NODE_COUNT=2

# Management cluster context (set after deploy-mgmt.sh completes)
export MGMTCTXT=kubeflow-mgmt
